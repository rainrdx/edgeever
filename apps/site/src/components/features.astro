---
import { Icon } from "astro-icon/components";
import { BorderBeam } from "@/components/magicui/border-beam";
import { MagicCard } from "@/components/magicui/magic-card";

const minorFeatures = [
  {
    title: "Web 端图片压缩",
    description: "上传前本地压缩为 WebP，限制最长边，极速且省流。",
    icon: "bx:bx-navigation",
  },
  {
    title: "PWA 与离线草稿",
    description: "可安装到桌面或手机。支持离线编辑与本地同步队列。",
    icon: "bx:bx-mobile",
  },
  {
    title: "数据开放可迁移",
    description: "基于标准 SQLite (D1)，API/CLI 按需读取、迁移或导出。",
    icon: "bx:bxs-lock-alt",
  },
  {
    title: "单用户登录授权",
    description: "PBKDF2-SHA256 密码哈希，支持创建 API Token 授权外部工具。",
    icon: "bx:bx-key",
  },
  {
    title: "印象笔记迁移",
    description: "提供完整 ENEX 导入脚本与按笔记本筛选迁移工作流。",
    icon: "bx:bx-transfer",
  },
];
---

<div class="mt-20 md:mt-32 relative">
  <!-- Decorative background elements -->
  <div class="absolute top-40 -left-20 w-72 h-72 bg-brand-border/10 rounded-full blur-3xl -z-10"></div>
  
  <div class="max-w-3xl mb-16 text-center mx-auto">
    <div class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-semibold text-brand-text bg-brand-soft/80 backdrop-blur border border-brand-border/40 rounded-full mb-5 shadow-sm">
      <Icon name="bx:bx-star" class="w-4 h-4 text-brand" />
      核心特性
    </div>
    <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900" id="features">
      重新定义个人笔记体验
    </h2>
    <p class="text-lg mt-5 text-slate-600 leading-relaxed">
      结合现代 Web 技术、Serverless 架构与 AI 代理能力，带来高效、开放、安全的内容工作区。
    </p>
  </div>

  <!-- Bento Box Layout -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(220px,auto)]">
    
    <!-- Bento Item 1: Cloudflare -->
    <div class="md:col-span-2 group relative overflow-hidden flex flex-col bg-white rounded-3xl border border-slate-200 hover-lift shadow-sm">
      <MagicCard client:visible className="p-8 flex flex-col items-start justify-start w-full h-full" gradientColor="#e8f6f1" gradientOpacity={0.4}>
        <BorderBeam size={300} duration={12} delay={9} className="z-20" colorFrom="#70c9b7" colorTo="#3fb2a1" client:visible />
        <div class="absolute top-0 right-0 w-64 h-64 bg-brand/10 rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3 group-hover:bg-brand/20 transition-colors duration-500 pointer-events-none"></div>
        <div class="bg-slate-50 p-3 rounded-2xl w-fit mb-6 border border-slate-100 group-hover:bg-brand-soft transition-colors relative z-10">
          <Icon class="text-slate-600 group-hover:text-brand-text w-8 h-8 transition-colors" name="bx:bx-dollar" />
        </div>
        <div class="relative z-10 mt-auto">
          <h3 class="font-bold text-2xl text-slate-800">Cloudflare 自托管部署</h3>
          <p class="text-slate-500 mt-3 leading-relaxed text-base max-w-lg">
            完全构建于 Cloudflare Workers、D1 和 R2 之上。个人短笔记可达 10 万条量级，200KB 图片约可存放 5 万张，以极低的成本拥有企业级可用性。
          </p>
        </div>
      </MagicCard>
    </div>

    <!-- Bento Item 2: AI Agent -->
    <div class="md:col-span-1 group relative overflow-hidden flex flex-col bg-brand-soft rounded-3xl border border-brand-border/30 hover-lift glow-card">
      <MagicCard client:visible className="p-8 flex flex-col items-start justify-start w-full h-full" gradientColor="#70c9b7" gradientOpacity={0.15}>
        <div class="bg-white/60 p-3 rounded-2xl w-fit mb-6 shadow-sm border border-white">
          <Icon class="text-brand-text w-8 h-8" name="bx:bxs-bot" />
        </div>
        <div class="mt-auto">
          <h3 class="font-bold text-xl text-slate-800">AI Agent 原生集成</h3>
          <p class="text-slate-600 mt-3 leading-relaxed text-sm">
            提供 REST API、OpenAPI schema 和 Remote MCP Endpoint。你的 AI 助手可以无缝读取、创建和整理所有笔记。
          </p>
        </div>
      </MagicCard>
    </div>

    <!-- Bento Item 3: Classic UI -->
    <div class="md:col-span-1 group relative overflow-hidden flex flex-col bg-white rounded-3xl border border-slate-200 hover-lift shadow-sm">
      <MagicCard client:visible className="p-8 flex flex-col items-start justify-start w-full h-full" gradientColor="#e8f6f1" gradientOpacity={0.4}>
        <div class="bg-slate-50 p-3 rounded-2xl w-fit mb-6 border border-slate-100 group-hover:bg-brand-soft transition-colors z-10">
          <Icon class="text-slate-600 group-hover:text-brand-text w-8 h-8 transition-colors" name="bx:bx-layout" />
        </div>
        <div class="mt-auto z-10">
          <h3 class="font-bold text-xl text-slate-800">经典三栏与嵌套</h3>
          <p class="text-slate-500 mt-3 leading-relaxed text-sm">
            无限级嵌套笔记本、拖拽排序、多选合并。保留你最熟悉的高效工作流。
          </p>
        </div>
      </MagicCard>
    </div>

    <!-- Bento Item 4: Rich Text Editor -->
    <div class="md:col-span-2 group relative overflow-hidden flex flex-col bg-white rounded-3xl border border-slate-200 hover-lift shadow-sm">
      <MagicCard client:visible className="p-8 flex flex-col items-start justify-start w-full h-full" gradientColor="#e8f6f1" gradientOpacity={0.4}>
        <div class="absolute bottom-0 right-0 w-1/2 h-full bg-gradient-to-l from-slate-50 to-transparent pointer-events-none"></div>
        <div class="bg-slate-50 p-3 rounded-2xl w-fit mb-6 border border-slate-100 group-hover:bg-brand-soft transition-colors relative z-10">
          <Icon class="text-slate-600 group-hover:text-brand-text w-8 h-8 transition-colors" name="bx:bx-edit-alt" />
        </div>
        <div class="mt-auto relative z-10">
          <h3 class="font-bold text-2xl text-slate-800">富文本与开放内容格式</h3>
          <p class="text-slate-500 mt-3 leading-relaxed text-base max-w-lg">
            基于 TipTap 的现代编辑器。数据同时保存为结构化 JSON、供 Agent 使用的 Markdown，以及供搜索的纯文本，绝不绑定数据。
          </p>
        </div>
      </MagicCard>
    </div>
  </div>

  <!-- Minor Features Grid -->
  <div class="mt-12 pt-12 border-t border-slate-100/60">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
      {
        minorFeatures.map((item) => (
          <div class="group flex flex-col items-center text-center p-4 rounded-2xl hover:bg-white hover:shadow-xl hover:shadow-slate-200/40 border border-transparent hover:border-slate-100 transition-all duration-300">
            <div class="bg-slate-50 rounded-xl p-3 mb-4 group-hover:bg-brand-soft group-hover:scale-110 transition-all duration-300">
              <Icon class="text-slate-400 group-hover:text-brand w-6 h-6 transition-colors" name={item.icon} />
            </div>
            <h4 class="font-semibold text-slate-800 text-sm mb-2">{item.title}</h4>
            <p class="text-slate-500 text-xs leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</div>
